{
  "compilerOptions": {
    "allowJs": true,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "maxNodeModuleJsDepth": 10,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "module": "esnext",
    "target": "es2023",
    "strict": true,
    "lib": [
      "es2023",
      "dom"
    ]
  },
  "include": [
    "./**/*.ts",
    "./types/**/*.d.ts",
    "./*.d.ts"
  ]
}